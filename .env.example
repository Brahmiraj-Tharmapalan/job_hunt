# Copy to .env.local and fill in. Never commit .env.local.
#
# Supabase: Project Settings → API
# These two are safe to expose to the browser (anon key is RLS-protected).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. DO NOT prefix with NEXT_PUBLIC_.
# Master key for the AES-256-GCM BYO-keys vault. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=
# SUPABASE_SERVICE_ROLE_KEY=    # added in a later step

# Public site URL (used by metadata, sitemap, OAuth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
